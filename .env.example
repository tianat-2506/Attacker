# Local development placeholders for the future MVP scaffold.
# Do not put real secrets in this file.

APP_ENV=development
APP_MODE=demo
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_APP_MODE=demo
DATA_DIR=./data
LOG_LEVEL=info
DATABASE_URL=sqlite:///backend/app/data/vietsupply.db
# Disposable PostgreSQL/PostGIS URL for live RLS smoke only.
# POSTGRES_TEST_DATABASE_URL=postgresql://user:password@localhost:5432/vietsupply_smoke

# Demo mode may use X-Demo-* headers. Set false for pilot/production.
ALLOW_DEMO_HEADERS=true

# Local dev JWT adapter. Replace with OIDC/JWKS configuration before pilot.
AUTH_PROVIDER=dev_jwt
AUTH_JWT_ISSUER=vietsupply-dev
AUTH_JWT_AUDIENCE=vietsupply-api
AUTH_JWT_SECRET=dev-secret-change-me
AUTH_JWT_CLOCK_SKEW_SECONDS=30
AUTH_JWKS_URL=

# OIDC signed-token smoke for pilot readiness proof.
# OIDC_SMOKE_TOKEN must be a disposable signed test token from the configured issuer.
# OIDC_SIGNED_TOKEN_LIVE_SMOKE=1
# OIDC_SMOKE_TOKEN=
# OIDC_SMOKE_EXPECTED_SUBJECT=
# OIDC_SMOKE_EXPECTED_ORGANIZATION_ID=
# OIDC_SMOKE_EXPECTED_ROLE=

# Evidence object storage live smoke.
# EVIDENCE_OBJECT_STORE_ENDPOINT=http://127.0.0.1:9000
# EVIDENCE_OBJECT_STORE_BUCKET=vietsupply-evidence
# EVIDENCE_OBJECT_STORE_ACCESS_KEY_ID=
# EVIDENCE_OBJECT_STORE_SECRET_ACCESS_KEY=
# EVIDENCE_OBJECT_STORE_REGION=us-east-1
# EVIDENCE_OBJECT_STORAGE_LIVE_SMOKE=1

# Evidence malware scanner live smoke.
# EVIDENCE_MALWARE_SCANNER=clamav
# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310
# EVIDENCE_MALWARE_SCANNER_LIVE_SMOKE=1

# Pilot/production guardrail:
# APP_MODE=pilot or production requires ALLOW_DEMO_HEADERS=false, AUTH_PROVIDER=oidc,
# AUTH_JWKS_URL, and PostgreSQL/PostGIS DATABASE_URL.
# DATABASE_URL=postgresql://user:password@host:5432/vietsupply
# Apply DB trust foundation first:
# python scripts/apply_postgres_migrations.py --plan-only
# python scripts/apply_postgres_migrations.py
# VITE_AUTH_TOKEN is only a local smoke-test helper; real UI should use an auth provider flow.
VITE_AUTH_TOKEN=

# Optional map provider. MVP can use Leaflet/OpenStreetMap without a token.
MAPBOX_TOKEN=
